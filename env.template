APP_NAME=zotero-paper-rag-v4
ENV=dev
LOG_LEVEL=INFO

ZOTERO_ROOT=/path/to/Zotero
# ZOTERO_SQLITE_PATH=/path/to/zotero.sqlite
# ZOTERO_STORAGE_DIR=/path/to/storage

OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini
CHAT_MAX_TOKENS=1800
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_FALLBACK_MODEL=text-embedding-3-small

VLM_MODEL=gpt-4.1-mini
ENABLE_FIGURE_VLM=true
PDF_RENDER_DPI=180
PDF_HI_RES_MAX_PAGES_PER_DOCUMENT=6
FIGURE_VLM_TIMEOUT_SECONDS=30
FIGURE_VLM_MAX_SIDE=1400

MILVUS_URI=http://localhost:19530
MILVUS_PAPER_COLLECTION=zprag_v4_papers
MILVUS_BLOCK_COLLECTION=zprag_v4_blocks

PAPER_BM25_TOP_K=12
PAPER_DENSE_TOP_K=12
BLOCK_BM25_TOP_K=16
BLOCK_DENSE_TOP_K=12
PAPER_LIMIT_DEFAULT=6
EVIDENCE_LIMIT_DEFAULT=14
UPSERT_BATCH_SIZE=128

DATA_DIR=./data
PAPER_STORE_PATH=./data/v4_papers.jsonl
BLOCK_STORE_PATH=./data/v4_blocks.jsonl
INGESTION_STATE_PATH=./data/v4_ingestion_state.json
SESSION_STORE_PATH=./data/v4_sessions.sqlite3
EVAL_CASES_PATH=./evals/cases_test_md.yaml

# Required for sensitive routes:
# - POST /api/v1/v4/ingest/rebuild
# - GET /api/v1/v4/library/papers/{paper_id}/pdf
ADMIN_API_KEY=replace_me_with_a_long_random_token
LIBRARY_API_KEY=replace_me_with_a_long_random_token
API_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_PER_WINDOW=10
PDF_RATE_LIMIT_PER_WINDOW=120

# Comma-separated browser origins allowed to call the API, e.g.
# CORS_ALLOW_ORIGINS=https://example.com,http://localhost:4321
CORS_ALLOW_ORIGINS=
